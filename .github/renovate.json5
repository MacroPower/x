{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":disableRateLimiting",
    ":separateMajorReleases",
    ":semanticCommits",
    ":automergeMinor",
  ],
  ignorePaths: [
    "**/testdata/**",
  ],
  postUpdateOptions: [
    "gomodTidy",
    "gomodUpdateImportPaths",
  ],
  customManagers: [
    // Tool and image versions pinned as Go constants in the Dagger
    // toolchain modules, annotated with `// renovate:` comments, e.g.:
    //   golangciLintVersion = "v2.12" // renovate: datasource=github-releases depName=golangci/golangci-lint
    //   defaultTrivyImage = "aquasec/trivy:0.68.2" // renovate: datasource=docker depName=aquasec/trivy
    // For image references, the version is the tag after the last colon.
    {
      customType: "regex",
      managerFilePatterns: ["/^toolchains/.+\\.go$/"],
      matchStrings: [
        '"(?:[^"]*:)?(?<currentValue>[^":]+)"\\s*// renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)',
      ],
      versioningTemplate: "{{#if (equals datasource 'docker')}}docker{{else}}semver-coerced{{/if}}",
    },
    // Tool versions pinned in Taskfiles as `<value> # renovate:` annotations,
    // e.g. the advisory deadcode pin:
    //   DEADCODE_VERSION: v0.45.0 # renovate: datasource=go depName=golang.org/x/tools
    // (devbox.json tool versions are handled by Renovate's built-in devbox
    // manager, so they need no customManager here.)
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)Taskfile\\.yaml$/", "/(^|/)\\.taskfiles/.+\\.yaml$/"],
      matchStrings: [
        '(?<currentValue>v?[0-9][^\\s#"]*)\\s*#\\s*renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)',
      ],
      versioningTemplate: "{{#if (equals datasource 'docker')}}docker{{else}}semver-coerced{{/if}}",
    },
  ],
}
