{
  "name": "x",
  "engineVersion": "v0.21.4",
  "toolchains": [
    {
      "name": "go",
      "source": "toolchains/go",
      "customizations": [
        {
          "argument": "source",
          "ignore": [".git", ".claude", ".worktrees", ".devbox", ".task", ".test", ".tmp", "dist", "toolchains"]
        },
        {
          "argument": "race",
          "default": "true"
        }
      ]
    },
    {
      "name": "security",
      "source": "toolchains/security",
      "customizations": [
        {
          "argument": "source",
          "ignore": [".git", ".claude", ".worktrees", ".devbox", ".task", ".test", ".tmp", "dist", "toolchains"]
        }
      ]
    },
    {
      "name": "devbox",
      "source": "toolchains/devbox",
      "customizations": [
        {
          "argument": "source",
          "ignore": [".git", ".claude", ".worktrees", ".devbox", ".task", ".test", ".tmp", "dist", "toolchains"]
        }
      ]
    },
    {
      "name": "prettier",
      "source": "toolchains/prettier",
      "customizations": [
        {
          "argument": "source",
          "ignore": [".git", ".claude", ".worktrees", ".devbox", ".task", ".test", ".tmp", "dist"]
        }
      ]
    },
    {
      "name": "zizmor",
      "source": "toolchains/zizmor",
